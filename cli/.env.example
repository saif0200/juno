PORT=3000
SESSION_TTL_MS=300000
SESSION_CLEANUP_INTERVAL_MS=30000
DEFAULT_TERMINAL_COLS=120
DEFAULT_TERMINAL_ROWS=40
OUTPUT_BUFFER_LIMIT=200000
CLAUDE_COMMAND=claude
CLAUDE_ARGS_JSON=[]
PAIRING_SERVER_NAME=
# Optional: public base URL when running behind a tunnel or reverse proxy.
# When set this overrides all auto-detected addresses in QR codes and the
# dashboard. Must be a full origin, e.g. https://abc123.ngrok.io
PUBLIC_URL=
PROJECTS_CONFIG_PATH=./projects.json
PROJECT_DISCOVERY_ENABLED=false
PROJECT_DISCOVERY_PATHS_JSON=[]
PROJECT_DISCOVERY_MAX_DEPTH=2
